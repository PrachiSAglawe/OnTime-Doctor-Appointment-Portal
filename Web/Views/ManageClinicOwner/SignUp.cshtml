<script type="text/javascript">
    $(function () {

        $("#CountryID").change(function () {
            var catid = $(this).val();
            $.ajax({
                url:`/ManageClinicOwner/GetstateJson?CountryID=${catid}`,
                type:"get",
                contentType:"application/json",
                success: function (result) {
                    // alert(JSON.stringify(result));
                    $("#StateID").empty();
                    let opt="";
                    var Firstrow=`<option value='0'>Select State</option>` 
                    $('#StateID').append(Firstrow);
                    $.each(result, function (ind, item) {
                         opt = `<option value=${item.stateID}>${item.stateName}</option>`;
                        $("#StateID").append(opt);
                    });
                },
                error:function(err)
                {
                    alert(JSON.stringify(err));
                }
            });
        });




        $("#StateID").change(function () {
            var sid = $(this).val();

            $.ajax({
                url:`/ManageClinicOwner/GetCityJson?stateid=${sid}`,
                type:"get",
                contentType:"application/json",
                success: function (result) {
                    // alert(JSON.stringify(result));
                    $("#CityID").empty();
                    $.each(result, function (ind, item) {
                        let opt = `<option value=${item.cityID}>${item.cityName}</option>`;
                        $("#CityID").append(opt);
                    });
                },
                error:function(err)
                {
                    alert(JSON.stringify(err));
                }
            });
        });

    });
</script>


