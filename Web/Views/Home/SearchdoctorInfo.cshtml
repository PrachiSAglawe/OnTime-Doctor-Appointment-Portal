@model IEnumerable<DoctorInfoDto>

 <div class="men">
    <div class="container">
        <div class="menu">
            
                @await Component.InvokeAsync("MenuVC")
        
        </div>
        <hr />
        <div class="row">
            <!-- Sidebar -->
            @await Component.InvokeAsync("SideMenuVC")
            <div class="col-md-9">
                <div>
                    <h2 class="text-center">Doctor List</h2>
                    <div class="divider mx-auto my-4"></div>
                    @foreach (var temp in Model)
                    {
                      
                         <div class="card mb-4 shadow-sm rounded-3">
                             <div class="card-header text-center" >
                                <h5 class="fw-bold text-primary">@temp.DoctorName</h5>
                             </div>
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <div class="col-lg-3 text-center">
                                        <img src="@temp.PhotoPath"
                                             class="img-fluid border rounded"
                                             width="160"
                                             height="120"
                                             style="object-fit: cover;" />

                                    </div>
                                    <div class="col-lg-6">
                                        <p class="mb-1"><strong>Clinic:</strong> @temp.ClinicName</p>
                                        <p class="mb-1"><strong>Address:</strong> @temp.ClinicAddress</p>
                                        <p class="mb-1"><strong>Mobile:</strong> @temp.MobileNo</p>
                                        <p class="mb-0"><strong>Email:</strong> @temp.EmailID</p>
                                        <p class="mb-0"><strong>SpecilityName:</strong> @temp.SpecilityName</p>
                                    </div>
                                    <div class="row text-center">
                                        <form asp-action="DoctorInfoCalender" asp-controller="Home" method="post">
                                            <input type="hidden" name="id" value="@temp.DoctorID" />
                                            <button type="submit" class="btn btn-main btn-primary" style="margin-top:70%">
                                                <i class="bi bi-calendar-check"></i> Book Appointment
                                            </button>
                                        </form>



                                    </div>
                                </div>
                            </div>
                        </div> 
                    }
                </div>
            </div>
        </div>
    </div>
</div>


<script type="text/javascript">
    $(function () {


          $("#GlobalCIID").change(function () {
            var cid = $(this).val();

            $.ajax({
                url:`/CommonJSON/GetAreaJSON?cityid=${cid}`,
                type:"get",
                contentType:"application/json",
                success: function (result) {
                    // alert(JSON.stringify(result));
                    $("#GlobalAID").empty();
                      let opt="";
                    var Firstrow=`<option value='0'>Select Area</option>`
                    $('#GlobalAID').append(Firstrow);
                    $.each(result, function (ind, item) {
                         opt = `<option value=${item.areaID}>${item.areaName}</option>`;
                        $("#GlobalAID").append(opt);
                    });
                },
                error:function(err)
                {
                    alert(JSON.stringify(err));
                }
            });
        });

    });
</script>








