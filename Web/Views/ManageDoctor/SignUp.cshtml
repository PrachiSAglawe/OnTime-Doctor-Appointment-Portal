@model DoctorSignUpDto
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>

<section class="page-title bg-1">
    <div class="overlay"></div>
    <div class="container">
       
        <div class="row">
            <div class="col-2">
            </div>
            <div class="col-md-8">
                <div class="card" style="border-radius: 15px;">
                    <div class="card-body p-5">
                        @TempData["Message"]
                        <h3 class=" text-center text-uppercase mb-2">Registration</h3>
                        <hr />
                        <form asp-action="SignUp" method="post" enctype="multipart/form-data">
                            <div asp-validation-summary="ModelOnly">
                            </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label asp-for="FirstName" class="form-label text-dark"></label>
                                    <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                                    <span asp-validation-for="FirstName"></span>
                                </div>
               
                            
                            <div class="col-6">
                            <label asp-for="LastName" class="form-label text-dark"></label>
                            <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                            <span asp-validation-for="LastName"></span>
                            </div>
                        </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label asp-for="MobileNo" class="form-label text-dark"></label>
                                    <input asp-for="MobileNo" class="form-control" placeholder="MobileNo" />
                                    <span asp-validation-for="MobileNo"></span>
                                </div>
                                <div class="col-6">
                                    <label asp-for="IsAvailable" class="form-label text-dark"></label>
                                    <br />
                                    <input asp-for="IsAvailable" style="height:30px;width:30px" />
                                    <span asp-validation-for="IsAvailable"></span>
                                </div>
                            </div>
                                           
                                            
                                          
                
                    <div class="row mb-3">
                        <div class="col-6">
                              <label asp-for="Address" class="form-label text-dark"></label>
                              <textarea asp-for="Address" class="form-control" placeholder="Address"></textarea>
                             <span asp-validation-for="Address"></span>
                            </div>

                        <div class="col-6">
                           <label asp-for="DoctorExperience" class="form-label text-dark"></label>
                             <input asp-for="DoctorExperience" class="form-control" placeholder="DoctorExperience" />
                              <span asp-validation-for="DoctorExperience"></span>
                        </div>

                    </div>
                    <div class="row mb-3">
                        <div class="col-4">
                          <label class="form-label text-dark">Select Country</label>
                              <select class="form-control" asp-for="CountryID" asp-items="@ViewBag.countries">
                                <option>Select Country</option>
                              </select>
                              <span asp-validation-for="CountryID"></span>
                        </div>

                        <div class="col-4">
                          <label class="form-label text-dark">Select State</label>
                          <select class="form-control" asp-for="StateID" asp-items="@ViewBag.states">
                               <option>Select State</option>
                           </select>
                           <span asp-validation-for="StateID"></span>
                        </div>
                        <div class="col-4">
                           <label class="form-label text-dark">Select City</label>
                            <select class="form-control" asp-for="CityID" asp-items="@ViewBag.cities">
                                  <option>Select City</option>
                            </select>
                            <span asp-validation-for="CityID"></span>
                        </div>
                                          

                    </div>
                    <div class="row mb-3">
                        <div class="col-4">
                            <label class="form-label text-dark">Select Area</label>
                            <select class="form-control" asp-for="AreaID" asp-items="@ViewBag.Areas">
                                <option>Select Area</option>
                            </select>
                            <span asp-validation-for="AreaID"></span>
                        </div>
                        <div class="col-4">
                            <label class="form-label text-dark">Select Clinic</label>
                            <select class="form-control" asp-for="ClinicID" asp-items="@ViewBag.clinics">
                                <option>Select Clinic</option>
                            </select>
                            <span asp-validation-for="ClinicID"></span>
                        </div>
                    </div>
                    <div class="row mb-4">


                        <div class="col-6">
                            <label for="inputNanme4" class="form-label font-18">Select Photo</label>
                            <input type="file" asp-for="PhotoFile" class="form-control" />
                            <span asp-validation-for="PhotoFile" class="text-danger"></span>
                        </div>
                        <div class="col-6">
                          <label asp-for="DoctorQualification" class="form-label text-dark"></label>
                          <input asp-for="DoctorQualification" class="form-control" placeholder="DoctorQualification" />
                          <span asp-validation-for="DoctorQualification"></span>
                        </div>
                    </div>
                                            

                    <h4>Login Info</h4>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label asp-for="Password" class="form-label text-dark"></label>
                            <input asp-for="Password" class="form-control" placeholder="Password" />
                        </div>
                        <div class="col-6">
                            <label asp-for="ConfirmPassword" class="form-label text-dark"></label>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="ConfirmPassword" />
                        </div>
                    </div> 
                    <div class="d-flex justify-content-center">
                        <button type="submit" data-mdb-button-init
                                data-mdb-ripple-init class="btn btn-info btn-block btn-main btn-lg gradient-custom-4 text-white ">
                            Register
                        </button>
                    </div>



            </form>
            <p class="text-center text-muted mt-5 mb-0">
                Have already an account? <a asp-action="SignIn" asp-controller="ManageDoctor"
                                            class="fw-bold text-body"><u>Login here</u></a>
            </p>

         </div>
        </div>
                            
            </div> 
        </div>
    </div>
</section>









<script type="text/javascript">
    $(function () {

        $("#CountryID").change(function () {
            var catid = $(this).val();

            $.ajax({
                url:`/ManageDoctor/GetstateJson?CountryID=${catid}`,
                type:"get",
                contentType:"application/json",
                success: function (result) {
                    // alert(JSON.stringify(result));
                    $("#StateID").empty();
                    let opt="";
                    var Firstrow=`<option value='0'>Select State</option>`
                    $('#StateID').append(Firstrow);
                    $.each(result, function (ind, item) {
                         opt = `<option value=${item.stateID}>${item.stateName}</option>`;
                        $("#StateID").append(opt);
                    });
                },
                error:function(err)
                {
                    alert(JSON.stringify(err));
                }
            });
        });




        $("#StateID").change(function () {
            var sid = $(this).val();

            $.ajax({
                url:`/ManageDoctor/GetCityJson?stateid=${sid}`,
                type:"get",
                contentType:"application/json",
                success: function (result) {
                    // alert(JSON.stringify(result));
                    $("#CityID").empty();
                     let opt="";
                    var Firstrow=`<option value='0'>Select city</option>`
                    $('#CityID').append(Firstrow);
                    $.each(result, function (ind, item) {
                        opt = `<option value=${item.cityID}>${item.cityName}</option>`;
                        $("#CityID").append(opt);
                    });
                },
                error:function(err)
                {
                    alert(JSON.stringify(err));
                }
            });
        });

          $("#CityID").change(function () {
            var cid = $(this).val();

            $.ajax({
                url:`/ManageDoctor/GetAreaJSON?cityid=${cid}`,
                type:"get",
                contentType:"application/json",
                success: function (result) {
                    // alert(JSON.stringify(result));
                    $("#AreaID").empty();
                     let opt="";
                    var Firstrow=`<option value='0'>Select Area</option>`
                    $('#AreaID').append(Firstrow);
                    $.each(result, function (ind, item) {
                         opt = `<option value=${item.areaID}>${item.areaName}</option>`;
                        $("#AreaID").append(opt);
                    });
                },
                error:function(err)
                {
                    alert(JSON.stringify(err));
                }
            });
        });

    });
</script> 