@model DoctorLoginDto
<div class="men">

    <section class="page-title bg-1">
        <div class="overlay" ></div>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="block ">
                        <div class="container">
                            <div class="register">
                                <div class="row">
                                    <div class="col-3"></div>
                                    <div class="col-md-6 login-right card">
                                        @TempData["Message"]
                                        <form asp-action="SignIn" method="post">
                                            <br /><br />
                                            <h3 class="text-center">Doctor-SignIn </h3><hr /><br />
                                            <div asp-validation-summary="ModelOnly" class="text-danger">
                                            </div>
                                            <div>
                                                <div class="form-group">
                                                    <input type="text" asp-for="MobileNo" class="form-control" placeholder="Your MobileNo">
                                                    <span asp-validation-for="MobileNo" class="text-danger"></span>
                                                </div>
                                            </div>
                                            <div>
                                                <div class="form-group">
                                                    <input class="form-control" asp-for="Password" placeholder="Your Password">
                                                    <span asp-validation-for="Password" class="text-danger"></span>
                                                </div>
                                            </div>
                                            <div>
                                                <div class="mb-3">
                                                  
                                                    <select asp-items="@ViewBag.SessionName" asp-for="OpdSessionID" class="form-control">
                                                        <option value="0">Select Session</option>
                                                    </select>
                                                    <span asp-validation-for="OpdSessionID"></span>
                                                </div>
                                                <input type="hidden" name="SessionName" id="sessionName" value=""/>
                                            </div>
                                            <div class="text-center">
                                                <input class="btn btn-main btn-round-full" name="submit" type="submit" value="Submit" id="session"  />
                                            </div><br />
                                            <div>
                                                <p class="mb-2 pb-lg-2" style="color: #393f81;">
                                                    Don't have an account? <a asp-action="SignUp"  asp-controller="ManageDoctor" style="color: #393f81;" class="text-primary">Register here</a>
                                                                              
                                                </p>
                                                <div class="text-black">
                                                    <h5>MobileNo : 9921357173</h5>
                                                    <h5>Password : 1234</h5>
                                                </div>
                                                
                                            </div><br />
                                        </form>

                                    </div>



                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section><br /><br />

</div>
<script type="text/javascript">
    $(function(){
        $("#session").click(function(){
            var SessionName=$("#OpdSessionID option:selected").text();
            // alert(SessionName);
            
            $("#sessionName").val(SessionName);
        });
    });
</script>