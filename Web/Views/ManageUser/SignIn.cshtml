@model LoginDto
<div class="men">

    <section class="page-title bg-1">
        <div class="overlay"></div>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="block ">
                        <div class="container">
                            <div class="register">
                                <div class="row">
                                    <div class="col-3"></div>
                                    <div class="col-md-6 login-right card">
                                        @TempData["Message"]
                                        <form asp-action="SignIn" method="post">
                                            <br /><br />
                                            <h3 class="text-center"> User-SignIn </h3><hr /><br />
                                            <div asp-validation-summary="ModelOnly" class="text-danger">
                                            </div>
                                            <div>
                                                <div class="form-group">
                                                    <input type="text" asp-for="EmailID" class="form-control" placeholder="Your EmailID">
                                                    <span asp-validation-for="EmailID" class="text-danger"></span>
                                                </div>
                                            </div>
                                            <div>
                                                <div class="form-group">
                                                    <input class="form-control" asp-for="Password" placeholder="Your Password">
                                                    <span asp-validation-for="Password" class="text-danger"></span>
                                                </div>
                                            </div>
                                            <div class="text-center">
                                                <input class="btn btn-main btn-round-full" name="submit" type="submit" value="Submit" />
                                            </div><br />
                                            <div>
                                                <p class="mb-2 pb-lg-2" style="color: #393f81;">
                                                    Don't have an account? <a asp-action="SignUp" asp-controller="ManageUser" style="color: #393f81;" class="text-primary">Register here</a>

                                                </p>
                                                <div class="text-black">
                                                    <h5>EmailID : Chaitali2512@gmail.com</h5>
                                                    <h5>Password : abcd</h5>
                                                </div>
                                            </div><br />
                                        </form>
                                       
                                    </div>



                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section><br /><br />

</div>


