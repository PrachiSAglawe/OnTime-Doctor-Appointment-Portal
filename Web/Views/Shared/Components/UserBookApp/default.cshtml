@model IEnumerable<BookedAppointments>
<div>
    <a class="btn btn-success text-white" asp-action="CreateNewAppoint" asp-controller="UserHome">New Appointment</a>
</div>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th> BookedAppoinmentID </th>
            <th> AppointmentDate </th>
            <th> StartTime</th>
            <th> Endtime </th>
            <th> DoctorClinicSessionID</th>
            <th>PatientName</th>
            <th>IsPaid</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var temp in Model)
        {
            <tr>
                <td>@temp.BookedAppointmentsID</td>
                <td>@temp.AppointmentDate</td>
                <td>@temp.StartTime</td>
                <td>@temp.EndTime</td>
                <td>@temp.DoctorClinicSessionID</td>
                <td>@temp.Patient.FullName</td>
                <td>@temp.IsPaid</td>
                <td>
                    <a class="btn btn-success" asp-action="PrintPrescription" asp-controller="UserHome" asp-route-id="@temp.PatientID"  asp-route-bookappoID="@temp.BookedAppointmentsID">PrescribeAndPrint</a>
                </td>
            </tr>
            

        }
    </tbody>
</table>


