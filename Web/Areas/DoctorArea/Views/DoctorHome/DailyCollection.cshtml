
<style>
    .custom-hover:hover {
        background-color: #007bff;
        color: white;
        border-color: black;
    }
</style>

<div class="card">
    <div class="card-header">
        <h3 class="text-center text-info mt-2">Select date and Get Daily Collection</h3>
    </div>
<div class="card-body">
        <form asp-action="DailyAppointCollect" method="post">
            <div class="row">
                <div class="col-md-4">
                    <label style="font-size:large" for="date"><b>Select Date:</b></label>
                    <input type="date" id="date" name="date" class="form-control">
                </div>
                <div style="margin-top:38px">
                    <input type="submit" value="Generate" class="btn btn-outline-primary  btn-danger text-white custom-hover" />
                </div>
            </div>
           
           
        </form>
    </div>
</div>







