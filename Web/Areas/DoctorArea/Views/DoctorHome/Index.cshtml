<div class="card">
    <div class="card-header  text-center">
        @* <h2>Welcome to Index Action of Doctor Controller</h2> *@
        @* <span class="text-success"> Login Doctor Name:@Context.Session.GetString("FullName")</span> *@

        <h3 class="text-info">DoctorName:@Context.Session.GetString("FullName") </h3>      
        <h4 class="text-info">Login DateTime: @DateTime.Now</h4>
        <h4 class="text-info">SessionName:@Context.Session.GetString("SessionName")</h4>

    </div><hr />
     <div class="card-body bg-gray text-center">

      <div class="text-danger">
            @TempData["Message"]
      </div>
        <div class="row">
            <div class="col-md-12">
                <div class="card card-primary card-outline card-tabs">
                    <div class="card-header p-0 pt-1 border-bottom-0">
                        <ul class="nav nav-tabs" id="custom-tabs-three-tab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="custom-tabs-three-home-tab" data-toggle="pill" href="#custom-tabs-three-home" role="tab" aria-controls="custom-tabs-three-home" aria-selected="true">New Appointment</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="custom-tabs-three-profile-tab" data-toggle="pill" href="#custom-tabs-three-profile" role="tab" aria-controls="custom-tabs-three-profile" aria-selected="false">Prescribe</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body">
                        <div class="tab-content" id="custom-tabs-three-tabContent">
                            <div class="tab-pane fade show active" id="custom-tabs-three-home" role="tabpanel" aria-labelledby="custom-tabs-three-home-tab">
                                @await Component.InvokeAsync("DoctorNewAppVC", new { doctorid = Convert.ToInt64(Context.Session.GetString("DoctorID")), sessionid = Convert.ToInt64(Context.Session.GetString("OpdSessionID")) })
                            </div>
                            <div class="tab-pane fade" id="custom-tabs-three-profile" role="tabpanel" aria-labelledby="custom-tabs-three-profile-tab">
                                @await Component.InvokeAsync("PrescribeVC", new { doctorid = Convert.ToInt64(Context.Session.GetString("DoctorID")), sessionid = Convert.ToInt64(Context.Session.GetString("OpdSessionID")) })
                            </div>
                        </div>
                    </div>
                    <!-- /.card -->
                </div>
            </div>
        </div>
       
       
</div>
</div>