@model IEnumerable<Area>

<div class="card">
    <div class="card-body">
       <ul>
            <li> <h1 class="card-title font-25 text-primary">Area List</h1></li>
       </ul>
       <hr />

        <a class="btn btn-success text-white" asp-action="Create">Create</a>
        <div class="text-danger">
            @TempData["Message"]
        </div>


        <div class="table-responsive pt-3">
            <table class="table table-bordered  table-hover">
                <thead class="font-18" style="background-color:antiquewhite">
                    <tr>
                        <th>
                            #
                        </th>
                        <th>
                           AreaID
                        </th>
                        <th>
                            AreaName
                        </th>
                        <th>
                            CityName
                        </th>
                        <th>
                            EditAction
                        </th>
                        <th>
                            DeleteAction
                        </th>

                    </tr>
                </thead>
                <tbody>

                    @{
                        int srNo = 1;
                    }
                    @foreach (var temp in Model)
                    {
                        <tr>
                            <td>@srNo</td>
                            <td>@temp.AreaID</td>
                            <td>@temp.AreaName</td>
                            <td>@temp.City.CityName</td>
                            <td><a asp-action="Edit" class="btn btn-primary" asp-route-id="@temp.AreaID">Edit</a></td>
                            <td><a asp-action="Delete" class="btn btn-danger" asp-route-id="@temp.AreaID">Delete</a></td>
                        </tr>
                        srNo++;
                    }

                </tbody>
            </table>
        </div>
    </div>
</div>