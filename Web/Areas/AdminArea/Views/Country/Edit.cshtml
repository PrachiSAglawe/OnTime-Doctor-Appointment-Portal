@model Country

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Edit</h5>
        <div class="text-danger">
            @TempData["Message"]
        </div>
        <!-- Vertical Form -->
        <form asp-action="Edit" method="post" class="row g-3">
            <input type="hidden" asp-for="CountryID"/>
            <div class="col-6">
                <label for="inputNanme4" class="form-label" asp-for="CountryName"></label>
                <input asp-for="CountryName" class="form-control" />
                <span asp-validation-for="CountryName" class="text-danger"></span>
            </div>
            <br />
            <div class="text-center mt-5">
                <button type="submit" class="btn btn-primary">Submit</button>
                <button type="reset" class="btn btn-secondary">Reset</button>
                <a class="btn btn-secondary" asp-action="Index">Back</a>
            </div>
        </form><!-- Vertical Form -->

    </div>
</div>