@model State


<div class="card">
    <div class="card-body">
        <h5 class="card-title font-18">Edit</h5>
        <hr />
        <div class="text-danger">
            @TempData["Message"]
        </div>
        <!-- Vertical Form -->
        <form asp-action="Edit" method="post" class="g-3">
            <input type="hidden" asp-for="StateID"/>
            <div>
                <div class="row">


                    <div class="col-6">
                        <label for="inputNanme4" class="form-label font-18" asp-for="StateName"></label>
                        <input asp-for="StateName" class="form-control" />
                        <span asp-validation-for="StateName" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label for="inputNanme4" class="form-label font-18">Select Country</label>
                        <select class="form-select form-control" asp-for="CountryID" asp-items="@ViewBag.Countries">
                            <option>Select Country</option>
                        </select>
                        <span asp-validation-for="CountryID" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
               



            <div class="text-center mt-3">
                <button type="submit" class="btn btn-primary">Submit</button>
                <button type="reset" class="btn btn-secondary">Reset</button>
                <a class="btn btn-secondary" asp-action="Index">Back</a>
            </div>
        </form><!-- Vertical Form -->

    </div>
</div>